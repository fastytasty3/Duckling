# Конфигурация для тестового окружения (vitest)

NODE_ENV=test

# Тестовая БД — изолированная от dev и prod
DATABASE_URL=postgresql://user:password@localhost:5432/scanner_test

# Статичный секрет для предсказуемых тестов
SESSION_SECRET=test-secret-static

# Rate limiting в test режиме поднят до 100 000 req/15 мин (см. app.ts)
# чтобы тесты не получали 429, но заголовки всё равно присутствуют
